---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="Home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hello 👋</div>
    <div class="text-5xl font-bold">I am Douraïd BEN HASSEN</div>
    <div class="text-3xl py-3 font-bold">AI Engineer | Generative AI & Agent Systems | Computer Vision | Azure Certified DP-100, AI-102</div>
    <div class="py-2">
      <text class="text-lg">
        As an AI engineer specializing in generative AI and agent systems, I design and deploy end-to-end AI platforms to production.
        <br><br>
        My expertise covers the entire AI lifecycle: multi-agent architecture, RAG, LLM pipelines, prompt engineering, API integration, and MLOps on Azure.
        <br><br>
        I have a strong background in Computer Vision and Deep Learning (detection, classification, OCR, anomaly detection, tracking) on ​​robust, industrialized systems.
        <br><br>
        🤖 Areas: Generative AI, LLM, Agent Systems, RAG, Computer Vision
        <br>
        ☁️ Stack: Python, FastAPI, Azure OpenAI, React/TypeScript, Docker, CI/CD
        <br>
        🚀 From Architecture to Production
      </text>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My latest projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Customs Assistant"
    img="/customs_assitant_agents.png"
    desc="AI Multi-Agent Platform for Customs Operations Automation. Intelligent assistant for shipment qualification, customs document generation, and workflow orchestration across operational customs tasks."
    url="/customs_assistant.pdf"
    badge="AI"
  />

  <HorizontalCard
    title="Fides AI"
    img="/fides_ai.png"
    desc="Multi-Agent System for Judicial Case Processing. AI-powered platform designed to qualify judicial files, automate procedural document production, and structure case workflows for legal operations."
    url="/POC_FIDES.pdf"
    badge="AI"
  />

  <HorizontalCard
    title="ASL Alphabet recognition"
    img="/asl_alphabet_recognition.png"
    desc="Hand landmark-based ASL fingerspelling recognition with 42D normalized features. MLP/DeepMLP/CNN architectures evaluated. K-Means & DBSCAN clustering for feature space analysis. Real-time webcam inference at 98%+ accuracy."
    url="https://github.com/Douraid-BEN-HASSEN/asl_alphabet_recognition"
    badge="AI"
  />

  <HorizontalCard
    title="Blood cell analysis"
    img="/blood_cell_analysis.png"
    desc="A comprehensive blood cell analysis system combining state-of-the-art object detection (YOLOv12) and deep learning classification (EfficientNet-B0) for automated hematology analysis. This system can detect and classify white blood cells (WBCs), red blood cells (RBCs), and platelets from microscopy images."
    url="https://github.com/Douraid-BEN-HASSEN/blood_cell_analysis"
    badge="AI"
  />

  <HorizontalCard
    title="Bacterial species classification"
    img="/bacterial_species_classification.png"
    desc="An advanced bacterial species classification system using transfer learning and computer vision. This project leverages ResNet50 with progressive unfreezing to identify 33 bacterial species from microscopy images, achieving 98.48% validation accuracy and 96.10% test accuracy on the DIBaS dataset."
    url="https://github.com/Douraid-BEN-HASSEN/bacterial_species_classification"
    badge="AI"
  />

  <HorizontalCard
    title="Facial expression recognition"
    img="/facial-expression-recognition.png"
    desc="A comprehensive comparison of deep learning architectures for facial expression recognition on the FER2013 dataset. This project explores four different approaches and achieves 69.99% accuracy with EfficientNet-B0."
    url="https://github.com/Douraid-BEN-HASSEN/facial-expression-recognition"
    badge="AI"
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Pill defect detection"
    img="/pill_defect_detection.png"
    desc="An advanced anomaly detection system for pharmaceutical quality control using deep learning. This project leverages a Convolutional Autoencoder with hybrid perceptual loss to identify defective pills in industrial vision applications."
    url="https://github.com/Douraid-BEN-HASSEN/pill_defect_detection"
    badge="AI"
  />

  <HorizontalCard
    title="Fish recognition"
    img="/fish_recognition_project.png"
    desc="Complex challenge solved: individually recognizing nearly identical fish (size, color, shape) in a moving aquarium by combining computer vision and deep learning."
    url="https://github.com/Douraid-BEN-HASSEN/fish_recognition"
    badge="AI"
  />

</BaseLayout>